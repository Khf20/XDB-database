<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="XDBDatabase_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="CardStrokeBrush" Color="#D9E2F1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F05A28" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#12824C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D92D20" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="NavTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EEF8" />
            <Setter Property="FontSize" Value="15" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="28,28,24,22" Orientation="Horizontal" Spacing="14">
                <Border Width="48" Height="48" Background="{StaticResource AccentBrush}" CornerRadius="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="X" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="XDB-database" />
                    <TextBlock Foreground="#AAB6C8" Text="Database control" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="20,8,20,0" Spacing="8">
                <Button
                    x:Name="DashboardNav"
                    Click="DashboardNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="Dashboard" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="LogsNav"
                    Click="LogsNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="Logs" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="PhpNav"
                    Click="PhpNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE943;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="PHP Switcher" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ToolsNav"
                    Click="ToolsNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="Tools" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border
                Grid.Row="2"
                Margin="20"
                Padding="16"
                Background="#1F2937"
                CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="SidebarStatusText"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Checking services" />
                    <TextBlock x:Name="SidebarTimeText" Foreground="#AAB6C8" Text="-" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Padding="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        x:Name="PageTitle"
                        FontSize="34"
                        FontWeight="Bold"
                        Text="Dashboard" />
                    <TextBlock Foreground="{StaticResource MutedBrush}" Text="C:\xampp" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Click="RefreshButton_Click" Content="Refresh" />
                    <Button
                        Background="#111827"
                        Click="PhpMyAdminButton_Click"
                        Content="phpMyAdmin"
                        Foreground="White" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <ScrollViewer
                    x:Name="DashboardView"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="14" RowSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="APACHE" />
                                    <TextBlock x:Name="ApacheVersionText" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="PHP VIA APACHE" />
                                    <TextBlock x:Name="ApachePhpText" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="PHP CLI" />
                                    <TextBlock x:Name="PhpCliText" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="MARIADB" />
                                    <TextBlock x:Name="MariaDbText" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="16" RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" MinHeight="190" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="26" FontWeight="Bold" Text="Apache" />
                                            <TextBlock x:Name="ApachePidText" Foreground="{StaticResource MutedBrush}" Text="PID -" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12,6"
                                            Background="#EAF8EF"
                                            CornerRadius="4">
                                            <TextBlock x:Name="ApacheStateText" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="Stopped" />
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        x:Name="ApachePortsText"
                                        Grid.Row="1"
                                        Margin="0,16,0,16"
                                        Foreground="{StaticResource MutedBrush}"
                                        Text="Port 80: -&#x0a;Port 443: -" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartApacheButton" Click="StartApacheButton_Click" Content="Start" />
                                        <Button x:Name="StopApacheButton" Click="StopApacheButton_Click" Content="Stop" />
                                        <Button x:Name="RestartApacheButton" Click="RestartApacheButton_Click" Content="Restart" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" MinHeight="190" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="26" FontWeight="Bold" Text="MySQL / MariaDB" />
                                            <TextBlock x:Name="MysqlPidText" Foreground="{StaticResource MutedBrush}" Text="PID -" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12,6"
                                            Background="#EAF8EF"
                                            CornerRadius="4">
                                            <TextBlock x:Name="MysqlStateText" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="Stopped" />
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        x:Name="MysqlPortsText"
                                        Grid.Row="1"
                                        Margin="0,16,0,16"
                                        Foreground="{StaticResource MutedBrush}"
                                        Text="Port 3306: -" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartMysqlButton" Click="StartMysqlButton_Click" Content="Start" />
                                        <Button x:Name="StopMysqlButton" Click="StopMysqlButton_Click" Content="Stop" />
                                        <Button x:Name="RestartMysqlButton" Click="RestartMysqlButton_Click" Content="Restart" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="LogsView" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="24" FontWeight="Bold" Text="Log Viewer" />
                                <TextBlock x:Name="LogPathText" Foreground="{StaticResource MutedBrush}" Text="-" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ComboBox x:Name="LogCombo" Width="180" SelectionChanged="LogCombo_SelectionChanged">
                                        <ComboBoxItem Content="Apache Error" IsSelected="True" />
                                        <ComboBoxItem Content="MySQL Error" />
                                        <ComboBoxItem Content="XAMPP Control" />
                                        <ComboBoxItem Content="Apache Access" />
                                    </ComboBox>
                                    <Button Click="ReloadLogButton_Click" Content="Reload" />
                                </StackPanel>
                            </StackPanel>
                            <TextBox
                                x:Name="LogBox"
                                Grid.Row="1"
                                AcceptsReturn="True"
                                FontFamily="Consolas"
                                IsReadOnly="True"
                                TextWrapping="NoWrap" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="PhpView" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="24" FontWeight="Bold" Text="PHP Switcher" />
                                <TextBlock Foreground="{StaticResource MutedBrush}" Text="Pilih PHP yang dipakai Apache. Setelah switch, restart Apache." />
                            </StackPanel>
                            <ListBox x:Name="PhpList" Grid.Row="1" />
                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                                <Button Click="ReloadPhpButton_Click" Content="Reload" />
                                <Button Click="UsePhpButton_Click" Content="Use for Apache" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="ToolsView" Visibility="Collapsed">
                    <Grid ColumnSpacing="14" RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="120" />
                            <RowDefinition Height="120" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Click="OpenHtdocs_Click" Content="Open htdocs" />
                        <Button Grid.Row="0" Grid.Column="1" Click="OpenApacheConfig_Click" Content="Open Apache config" />
                        <Button Grid.Row="0" Grid.Column="2" Click="OpenMysqlData_Click" Content="Open MySQL data" />
                        <Button Grid.Row="1" Grid.Column="0" Click="OpenRoot_Click" Content="Open C:\xampp" />
                        <Button Grid.Row="1" Grid.Column="1" Click="PhpMyAdminButton_Click" Content="Open phpMyAdmin" />
                        <Button Grid.Row="1" Grid.Column="2" Click="OpenDashboard_Click" Content="Open XAMPP dashboard" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
