<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="XDBDatabase_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#151A1F"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#101722" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9CA8B8" />
        <SolidColorBrush x:Key="CardStrokeBrush" Color="#334050" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F05A28" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#52D66B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF4B4B" />
        <SolidColorBrush x:Key="PageBrush" Color="#151A1F" />
        <SolidColorBrush x:Key="CardBrush" Color="#20262C" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="22" />
        </Style>
        <Style x:Key="NavTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EEF8" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style x:Key="ServiceButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="Height" Value="42" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="ToolTileStyle" TargetType="Button">
            <Setter Property="Height" Value="168" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="#202A35" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2F3B49" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="28,28,24,22" Orientation="Horizontal" Spacing="14">
                <Border Width="48" Height="48" Background="{StaticResource AccentBrush}" CornerRadius="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="X" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="XDB-database" />
                    <TextBlock Foreground="#AAB6C8" Text="Database control" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="20,8,20,0" Spacing="8">
                <Button
                    x:Name="DashboardNav"
                    Click="DashboardNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="Dashboard" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="LogsNav"
                    Click="LogsNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="Logs" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="PhpNav"
                    Click="PhpNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE943;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="PHP Switcher" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ToolsNav"
                    Click="ToolsNav_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                        <TextBlock Style="{StaticResource NavTextStyle}" Text="Tools" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Row="2" Margin="20" Padding="16" Background="#1C2734" CornerRadius="10">
                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="SidebarStatusText"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Checking services" />
                    <TextBlock x:Name="SidebarTimeText" Foreground="#AAB6C8" Text="-" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Padding="28" Background="{StaticResource PageBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        x:Name="PageTitle"
                        FontSize="34"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Dashboard" />
                    <TextBlock Foreground="{StaticResource MutedBrush}" Text="C:\xampp" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Click="RefreshButton_Click" Content="Refresh" />
                    <Button
                        Background="#111827"
                        Click="PhpMyAdminButton_Click"
                        Content="phpMyAdmin"
                        Foreground="White" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <ScrollViewer
                    x:Name="DashboardView"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="Total Active Services" />
                                    <TextBlock x:Name="ActiveServicesText" FontSize="46" FontWeight="Bold" Foreground="White" Text="0" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="DashboardClockText"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    Foreground="White"
                                    Text="00:00:00" />
                            </Grid>
                        </Border>

                        <Grid ColumnSpacing="14" RowSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Padding="16" CornerRadius="14" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="APACHE" />
                                    <TextBlock x:Name="ApacheVersionText" FontWeight="SemiBold" Foreground="White" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Padding="16" CornerRadius="14" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="PHP VIA APACHE" />
                                    <TextBlock x:Name="ApachePhpText" FontWeight="SemiBold" Foreground="White" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Padding="16" CornerRadius="14" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="PHP CLI" />
                                    <TextBlock x:Name="PhpCliText" FontWeight="SemiBold" Foreground="White" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Padding="16" CornerRadius="14" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="MARIADB" />
                                    <TextBlock x:Name="MariaDbText" FontWeight="SemiBold" Foreground="White" Text="-" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="16" RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" MinHeight="230" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="Apache" />
                                            <TextBlock x:Name="ApachePidText" Foreground="{StaticResource MutedBrush}" Text="PID -" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12,6"
                                            Background="#EAF8EF"
                                            CornerRadius="4">
                                            <TextBlock x:Name="ApacheStateText" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="Stopped" />
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        x:Name="ApachePortsText"
                                        Grid.Row="1"
                                        Margin="0,18,0,18"
                                        FontSize="17"
                                        Foreground="{StaticResource MutedBrush}"
                                        Text="Port 80: -&#x0a;Port 443: -" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartApacheButton" Background="#43D166" Click="StartApacheButton_Click" Content="Start" Foreground="White" Style="{StaticResource ServiceButtonStyle}" />
                                        <Button x:Name="StopApacheButton" Background="#FF444B" Click="StopApacheButton_Click" Content="Stop" Foreground="White" Style="{StaticResource ServiceButtonStyle}" />
                                        <Button x:Name="RestartApacheButton" Background="#229CF7" Click="RestartApacheButton_Click" Content="Restart" Foreground="White" Style="{StaticResource ServiceButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" MinHeight="230" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="MySQL / MariaDB" TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="MysqlPidText" Foreground="{StaticResource MutedBrush}" Text="PID -" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12,6"
                                            Background="#EAF8EF"
                                            CornerRadius="4">
                                            <TextBlock x:Name="MysqlStateText" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="Stopped" />
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        x:Name="MysqlPortsText"
                                        Grid.Row="1"
                                        Margin="0,18,0,18"
                                        FontSize="17"
                                        Foreground="{StaticResource MutedBrush}"
                                        Text="Port 3306: -" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartMysqlButton" Background="#43D166" Click="StartMysqlButton_Click" Content="Start" Foreground="White" Style="{StaticResource ServiceButtonStyle}" />
                                        <Button x:Name="StopMysqlButton" Background="#FF444B" Click="StopMysqlButton_Click" Content="Stop" Foreground="White" Style="{StaticResource ServiceButtonStyle}" />
                                        <Button x:Name="RestartMysqlButton" Background="#229CF7" Click="RestartMysqlButton_Click" Content="Restart" Foreground="White" Style="{StaticResource ServiceButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="LogsView" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="24" FontWeight="Bold" Text="Log Viewer" />
                                <TextBlock x:Name="LogPathText" Foreground="{StaticResource MutedBrush}" Text="-" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ComboBox x:Name="LogCombo" Width="180" SelectionChanged="LogCombo_SelectionChanged">
                                        <ComboBoxItem Content="Apache Error" IsSelected="True" />
                                        <ComboBoxItem Content="MySQL Error" />
                                        <ComboBoxItem Content="XAMPP Control" />
                                        <ComboBoxItem Content="Apache Access" />
                                    </ComboBox>
                                    <Button Click="ReloadLogButton_Click" Content="Reload" />
                                </StackPanel>
                            </StackPanel>
                            <TextBox
                                x:Name="LogBox"
                                Grid.Row="1"
                                AcceptsReturn="True"
                                FontFamily="Consolas"
                                IsReadOnly="True"
                                TextWrapping="NoWrap" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="PhpView" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="24" FontWeight="Bold" Text="PHP Switcher" />
                                <TextBlock Foreground="{StaticResource MutedBrush}" Text="Pilih PHP yang dipakai Apache. Setelah switch, restart Apache." />
                            </StackPanel>
                            <ListBox x:Name="PhpList" Grid.Row="1" />
                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                                <Button Click="ReloadPhpButton_Click" Content="Reload" />
                                <Button Click="UsePhpButton_Click" Content="Use for Apache" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <ScrollViewer x:Name="ToolsView" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <Grid ColumnSpacing="18" RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="168" />
                            <RowDefinition Height="168" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Click="OpenHtdocs_Click" Style="{StaticResource ToolTileStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="44" Glyph="&#xE8B7;" />
                                <TextBlock FontSize="22" Text="Open htdocs" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="1" Click="OpenApacheConfig_Click" Style="{StaticResource ToolTileStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="44" Glyph="&#xE713;" />
                                <TextBlock FontSize="22" Text="Apache Config" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="2" Click="OpenMysqlData_Click" Style="{StaticResource ToolTileStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="44" Glyph="&#xE8FC;" />
                                <TextBlock FontSize="22" Text="MySQL Data" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="0" Click="OpenRoot_Click" Style="{StaticResource ToolTileStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="44" Glyph="&#xE838;" />
                                <TextBlock FontSize="22" Text="Open C:\xampp" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="1" Click="PhpMyAdminButton_Click" Style="{StaticResource ToolTileStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="44" Glyph="&#xE968;" />
                                <TextBlock FontSize="22" Text="phpMyAdmin" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="2" Click="OpenDashboard_Click" Style="{StaticResource ToolTileStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="44" Glyph="&#xF246;" />
                                <TextBlock FontSize="22" Text="Server Status" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
